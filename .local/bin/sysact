#!/bin/sh

# A dmenu wrapper script for system functions.
export WM="dwl"
case "$(readlink -f /sbin/init)" in
	*systemd*) ctl='systemctl' ;;
	*) ctl='loginctl' ;;
esac

wmpid(){ # This function is needed if there are multiple instances of the window manager.
	tree="$(pstree -ps $$)"
	tree="${tree#*$WM(}"
	echo "${tree%%)*}"
}

case "$(printf "ï€£ lock\nó° œ leave $WM\nó±£» hibernate\nó°œ‰ reboot\nï€‘ shutdown\nó°’² sleep" | tofi --fuzzy-match true --prompt-text 'Action: ')" in
	'ï€£ lock') slock ;;
	"ó° œ leave $WM") kill -TERM "$(wmpid)" ;;
	'ó±£» hibernate') slock $ctl hibernate -i ;;
	'ó°’² sleep') slock $ctl suspend -i ;;
	'ó°œ‰ reboot') $ctl reboot -i ;;
	'ï€‘ shutdown') $ctl poweroff -i ;;
	*) exit 1 ;;
esac
